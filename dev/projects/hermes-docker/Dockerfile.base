# ========================================
# Layer 1: Hermes Agent Base
# 系统依赖 + Node.js + Python + Playwright
# 这层很少变化，构建一次即可复用
# ========================================
FROM ghcr.nju.edu.cn/astral-sh/uv:0.11.6-python3.13-trixie@sha256:b3c543b6c4f23a5f2df22866bd7857e5d304b67a564f4feab6ac22044dde719b AS uv_source
FROM tianon/gosu:1.19-trixie@sha256:3b176695959c71e123eb390d427efc665eeb561b1540e82679c15e992006b8b9 AS gosu_source
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright

# 系统依赖（不常变）
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential nodejs npm python3 ripgrep ffmpeg gcc python3-dev libffi-dev procps git && \
    rm -rf /var/lib/apt/lists/*

# 创建用户
RUN useradd -u 10000 -m -d /opt/data hermes

# 工具（不常变）
COPY --chmod=0755 --from=gosu_source /gosu /usr/local/bin/
COPY --chmod=0755 --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/

# 预装 Playwright chromium（大，约 200MB，不常变）
RUN npx playwright install --with-deps chromium --only-shell || true

WORKDIR /opt/hermes

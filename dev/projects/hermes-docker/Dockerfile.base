# ========================================
# Layer 1: Hermes Agent Base
# 系统依赖 + Node.js + Python + Playwright + uv + Claude Code
# ========================================
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright

# 系统依赖 + 常用工具
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        # 基础开发
        build-essential nodejs npm python3 python3-venv python3-pip python3-dev \
        ripgrep ffmpeg gcc libffi-dev procps git curl ca-certificates \
        # Shell 增强
        tmux zsh fonts-powerline sudo wget xz-utils \
        # 系统工具
        tree htop ncdu fastfetch \
        # Git 增强
        lazygit gh delta \
        # 文件/搜索
        bat eza fd fzf zoxide \
        # 数据处理
        jq yq httpie \
        && rm -rf /var/lib/apt/lists/*

# 安装 uv
RUN curl -LsSf https://astral.sh/uv/0.11.6/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

# 安装 Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# 预装 Playwright chromium
RUN npx playwright install --with-deps chromium --only-shell || true

WORKDIR /opt
